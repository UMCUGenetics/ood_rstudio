batch_connect:
  template: "basic"
  conn_params:
    - csrftoken

script:
  native: [
            "-N", "1",
            <%- if not bc_scratch.blank? -%>
             "--gres", "tmpspace:<%= bc_scratch.to_i %>G",
            <% else -%>
             "--gres", "tmpspace:50G",
            <% end -%>
            "--signal", "USR2",
            "-c", "<%= bc_cpus.blank?  ? 1 : bc_cpus.to_i %>",
            <%- if not bc_mem.blank? -%>
             "--mem", "<%= bc_mem.to_i %>G",
            <%- end -%>
            "--account", "<%= auto_accounts %>",
            <%- if bc_partition == "gpu" -%>
              "--partition", "<%= bc_partition %>",
             <%- if not bc_gpus.blank? -%>
              "--gpus-per-node", "<%= bc_gpus %>:1",
             <%- else -%>
              "--gpus-per-node", "tesla_v100-pcie-16gb:1",
             <%- end -%>
            <%- end -%>
          ]
